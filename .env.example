# ===========================================================================
# Memory Journal — Environment Variables
# ===========================================================================
# Copy this file to .env and fill in the values before running locally.
# Never commit your real .env file — it is listed in .gitignore.
# ===========================================================================

# ---------------------------------------------------------------------------
# OpenAI (required for AI story generation)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here

# ---------------------------------------------------------------------------
# Supabase (required when using Supabase for auth and/or storage)
# Set these to enable full JWT verification in the API layer.
# ---------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here
# Frontend public keys (safe to expose in the browser bundle)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ---------------------------------------------------------------------------
# API endpoint overrides (frontend — optional)
# Defaults shown; only set if you need to point at a different URL.
# ---------------------------------------------------------------------------
# VITE_LLM_API_ENDPOINT=/api/llm/complete
# VITE_AUTH_USER_ENDPOINT=/api/auth/me
# VITE_PREFERENCES_API_ENDPOINT=/api/preferences

# ---------------------------------------------------------------------------
# LLM rate limits (optional — defaults shown)
# ---------------------------------------------------------------------------
# Maximum number of AI requests per user per 10-minute window (free tier)
FREE_AI_LIMIT_10M=10
# Maximum number of AI requests per user per day (free tier)
FREE_AI_LIMIT_DAY=50
# Maximum number of AI requests per user per 10-minute window (premium tier)
PREMIUM_AI_LIMIT_10M=60
# Maximum number of AI requests per user per day (premium tier)
PREMIUM_AI_LIMIT_DAY=500
# Comma-separated list of user IDs that receive premium limits
# PREMIUM_USER_IDS=user_123,user_456

# ---------------------------------------------------------------------------
# LLM input validation (optional — defaults shown)
# ---------------------------------------------------------------------------
# Maximum allowed prompt size in characters
MAX_LLM_PROMPT_CHARS=12000

# ---------------------------------------------------------------------------
# Strict authentication mode (optional — defaults shown)
# Set to "true" to reject API requests that have no authenticated user.
# ---------------------------------------------------------------------------
REQUIRE_AUTH_FOR_LLM=false
REQUIRE_AUTH_FOR_PREFERENCES=false

# ---------------------------------------------------------------------------
# Sentry (optional — frontend error tracking)
# Leave empty to disable. Create a project at sentry.io and paste the DSN.
# ---------------------------------------------------------------------------
# VITE_SENTRY_DSN=
# VITE_SENTRY_ENV=production
# VITE_APP_RELEASE=

# ---------------------------------------------------------------------------
# Stripe (required for premium subscription and printed-book checkout)
# ---------------------------------------------------------------------------
# Server-side secret key (sk_test_... in dev, sk_live_... in production)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
# Webhook signing secret for /api/stripe/webhook (whsec_...)
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
# Price IDs for the premium subscription tiers
STRIPE_PRICE_PREMIUM_MONTHLY=price_your-monthly-price-id
STRIPE_PRICE_PREMIUM_ANNUAL=price_your-annual-price-id
# Frontend publishable key (safe to expose in the browser bundle)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key

# ---------------------------------------------------------------------------
# Browserless.io (required for server-side PDF rendering of printed books)
# ---------------------------------------------------------------------------
BROWSERLESS_API_KEY=your-browserless-api-key
# Optional region override; defaults to production.browserless.io
# BROWSERLESS_BASE_URL=https://production-sfo.browserless.io

# ---------------------------------------------------------------------------
# Lulu xPress (required for print-on-demand book fulfillment)
# https://developers.lulu.com/
# ---------------------------------------------------------------------------
# "sandbox" for testing (no real shipments), "production" for live orders
LULU_ENV=sandbox
LULU_CLIENT_KEY=your-lulu-client-key
LULU_CLIENT_SECRET=your-lulu-client-secret
# Margin added on top of POD base cost + shipping, in basis points (500 = 5%)
# LULU_MARGIN_BPS=500
